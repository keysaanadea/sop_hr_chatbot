# =============================================
# DENAI AI — Environment Variables Template
# Copy ke .env dan isi dengan nilai asli
# JANGAN commit .env ke git!
# =============================================

# Server
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=https://yourdomain.com   # domain DigitalOcean kamu

# OpenAI
OPENAI_API_KEY=sk-...

# Pinecone (RAG)
PINECONE_API_KEY=...
PINECONE_HOST=...
PINECONE_INDEX_NAME=...

# Supabase (Database)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_DB_PASSWORD=...
SUPABASE_CONNECTION_STRING=postgresql://...

# ElevenLabs (Voice)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_INDONESIAN=...

# Cohere (Reranker)
COHERE_API_KEY=...

# Langfuse (Observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Upstash Redis (Cache)
UPSTASH_REDIS_URL=...
UPSTASH_REDIS_TOKEN=...

# Google Maps (opsional)
GOOGLE_MAPS_API_KEY=...
